# Sao chep file nay thanh .env va tu dien gia tri that. KHONG commit file .env vao git.

# Page Access Token cua Fanpage (tu tao trong Meta for Developers, quyen pages_manage_engagement + pages_read_engagement)
PAGE_ACCESS_TOKEN=

# ID cua Fanpage tren Facebook
PAGE_ID=

# Chuoi tuy chon ban tu dat, dung de Facebook xac thuc webhook
VERIFY_TOKEN=

# Cong chay server webhook
PORT=3000

# (Tuy chon) API key cho dich vu AI ben ngoai neu muon sinh cau tra loi phong phu hon
AI_API_KEY=

# Nhan hien thi truoc moi cau tra loi tu dong, dam bao minh bach voi khach hang
AUTO_REPLY_LABEL=[Tro ly ao Fanpage]
